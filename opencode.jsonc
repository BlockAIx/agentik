{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet-4.6",
  "agent": {
    "build": {
      "model": "github-copilot/claude-sonnet-4.6",
      "max_steps": 3,
      "permission": {
        "bash": {
          "git status *": "allow",
          "git diff *": "allow",
          "git add *": "allow",
          "git commit *": "allow",
          "git push *": "deny"
        }
      }
    },
    "fix": {
      "model": "github-copilot/claude-sonnet-4.6",
      "max_steps": 3,
      "permission": {
        "bash": {
          "git status *": "allow",
          "git diff *": "allow",
          "git add *": "allow",
          "git commit *": "allow",
          "git push *": "deny"
        }
      }
    },
    "architect": {
      "model": "github-copilot/claude-opus-4.6",
      "max_steps": 3,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny"
        }
      }
    },
    "milestone": {
      "model": "github-copilot/claude-sonnet-4.6",
      "max_steps": 3,
      "permission": {
        "edit": "deny",
        "bash": {
          "git status *": "allow",
          "git diff *": "allow",
          "git log *": "allow",
          "git show *": "allow",
          "cat *": "allow",
          "find *": "allow",
          "ls *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "wc *": "allow",
          "grep *": "allow",
          "git push *": "deny",
          "git merge *": "deny",
          "git tag *": "deny",
          "git checkout *": "deny",
          "git branch *": "deny",
          "rm *": "deny"
        }
      }
    }
  }
}